# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real values.

# CloudFront distribution ID (aws cloudfront list-distributions)
DISTRIBUTION_ID=

# S3 bucket name (default: terrythomas-bio)
# BUCKET=terrythomas-bio

# AWS CLI named profile (default: terrythomas)
# AWS_PROFILE=terrythomas
